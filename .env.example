
# Digital Twin 开发环境变量配置模板
# 使用方式: cp .env.example .env 然后修改对应的值

# JWT 认证密钥（至少32字符）
export JWT_SECRET="your-jwt-secret-key-at-least-32-characters"

# ========== 大模型配置 ==========
# LLM 模式: "api"(调用真实API) 或 "mock"(返回预设回复，零成本测试)
export LLM_MODE="mock"

# 通义千问（阿里云百炼平台）- qwen-turbo 完全免费
# 获取 API Key: https://bailian.console.aliyun.com/
export OPENAI_API_KEY="sk-your-dashscope-api-key-here"
export OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
export LLM_MODEL="qwen-turbo"

# 其他可选模型（取消注释切换）:
# export LLM_MODEL="qwen-plus"       # 质量更好，100万token免费
# export LLM_MODEL="qwen-max"        # 最高质量，100万token免费

# 如需切换到其他提供商，修改 OPENAI_BASE_URL 和 OPENAI_API_KEY 即可:
# DeepSeek:     export OPENAI_BASE_URL="https://api.deepseek.com/v1"
# SiliconFlow:  export OPENAI_BASE_URL="https://api.siliconflow.cn/v1"
# OpenAI:       export OPENAI_BASE_URL="https://api.openai.com/v1"

# ========== 向量数据库配置 ==========
# 向量数据库模式: "memory"(内存模式,无需外部依赖) 或 "chroma"(需要 Chroma DB 服务)
export VECTOR_DB_MODE="memory"

# Chroma DB 配置（仅 VECTOR_DB_MODE=chroma 时生效）
export CHROMA_HOST="localhost"
export CHROMA_PORT="8000"

# ========== 服务配置 ==========
# 服务端口
export SERVER_PORT="8080"

# 运行环境: development | test | production
export APP_ENV="development"
