# ====== 运行环境配置 ======
PORT=8080
ENV=production
DEBUG=false

# ====== 安全配置 ======
# JWT_SECRET 需要部署前修改为复杂随机字符串
JWT_SECRET=your_production_jwt_secret_key_change_me

# ====== 大模型与外部 API ======
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ====== 数据库配置 ======
DB_DRIVER=sqlite3
DB_DSN=file:data/sqlite/digital_twin.db?cache=shared&mode=rwc

# ====== 内部服务调用 ======
# 后端调用 Knowledge 模块的地址
KNOWLEDGE_API_URL=http://knowledge:8100/api/v1
