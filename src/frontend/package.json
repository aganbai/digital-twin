{
  "name": "digital-twin-miniapp",
  "version": "1.0.0",
  "private": true,
  "description": "AI 数字分身小程序",
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "npm run build:weapp -- --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "npm run build:h5 -- --watch",
    "test:e2e": "jest --config e2e/jest.config.js e2e/full-flow.test.js --forceExit --testTimeout=120000",
    "test:e2e:student": "jest --config e2e/jest.config.js e2e/student-flow.test.js --forceExit --testTimeout=120000",
    "test:e2e:teacher": "jest --config e2e/jest.config.js e2e/teacher-flow.test.js --forceExit --testTimeout=120000",
    "test:e2e:persona": "jest --config e2e/jest.config.js e2e/persona-flow.test.js --forceExit --testTimeout=120000",
    "test:e2e:all": "jest --config e2e/jest.config.js e2e/ --forceExit --testTimeout=120000",
    "test:e2e:check": "node e2e/smoke-check.js"
  },
  "dependencies": {
    "@tarojs/cli": "3.6.31",
    "@tarojs/components": "3.6.31",
    "@tarojs/helper": "3.6.31",
    "@tarojs/plugin-framework-react": "3.6.31",
    "@tarojs/plugin-platform-weapp": "3.6.31",
    "@tarojs/react": "3.6.31",
    "@tarojs/runtime": "3.6.31",
    "@tarojs/shared": "3.6.31",
    "@tarojs/taro": "3.6.31",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/runtime": "^7.24.0",
    "@tarojs/webpack5-runner": "3.6.31",
    "@types/react": "^18.2.0",
    "babel-preset-taro": "3.6.31",
    "jest": "^30.3.0",
    "miniprogram-automator": "^0.12.1",
    "sass": "^1.71.0",
    "typescript": "^5.3.0",
    "webpack": "5.91.0"
  }
}
