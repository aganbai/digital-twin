# 沙盒部署配置示例
# 复制此文件为 .env.sandbox 并填写实际配置

# ==================== SSH 连接配置 ====================
# 沙盒服务器地址
SANDBOX_HOST=192.168.1.100

# SSH 用户名
SANDBOX_USER=root

# SSH 端口
SANDBOX_PORT=22

# 沙盒服务器上的部署目录
SANDBOX_DEPLOY_DIR=/opt/digital-twin

# ==================== 镜像仓库配置（可选） ====================
# 如果配置了镜像仓库，部署时会先推送镜像到仓库
# IMAGE_REGISTRY=registry.example.com/digital-twin

# ==================== 部署选项 ====================
# 是否跳过测试
SKIP_TESTS=false

# 健康检查最大重试次数
HEALTH_CHECK_RETRIES=30

# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=10
